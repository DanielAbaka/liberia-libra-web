# Copy to .env and fill in (Vite only reads .env / .env.local — not this file).
# See scripts/google-sheet-contact-webapp.gs for setup.

VITE_GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Optional: same random string as EXPECTED_SECRET in Apps Script (not the deployment ID from the URL).
# VITE_CONTACT_FORM_SECRET=
